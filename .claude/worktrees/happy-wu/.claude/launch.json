{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Firebase Hosting (firebase serve)",
      "runtimeExecutable": "firebase",
      "runtimeArgs": ["serve", "--only", "hosting", "--port", "5001"],
      "port": 5001
    },
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    }
  ]
}
